# Backend Environment Variables

# JWT Secret Key (generate with: openssl rand -hex 32)
# REQUIRED: Change this in production!
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database URL
# SQLite (default, for local dev):
DATABASE_URL=sqlite:///./prozapas.db
# PostgreSQL (for production, example):
# DATABASE_URL=postgresql+psycopg2://prozapas:password@db:5432/prozapas

# CORS Origins (comma-separated)
# Add your production domain here (use https:// for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://yourdomain.com
